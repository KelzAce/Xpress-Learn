@page
@model XpressLearn.Pages.Courses.IndexModel
@{
    ViewData["Title"] = "Courses";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2">📚 Courses</h1>
        <a asp-page="Create" class="btn btn-primary">+ New Course</a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover table-striped align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Thumbnail</th>
                    <th>Title</th>
                    <th>Category</th>
                    <th>Instructor</th>
                    <th>Level</th>
                    <th>Price</th>
                    <th>Published</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var course in Model.Courses)
                {
                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(course.ThumbnailUrl))
                            {
                                <img src="@course.ThumbnailUrl" alt="Thumbnail" class="rounded" style="width:60px;height:40px;object-fit:cover;" />
                            }
                            else
                            {
                                <span class="text-muted">No image</span>
                            }
                        </td>
                        <td><strong>@course.Title</strong></td>
                        <td><span class="badge bg-secondary">@course.CategoryName</span></td>
                        <td>@course.InstructorName</td>
                        <td>
                            @{
                                var levelClass = course.Level switch {
                                    "Beginner" => "bg-success",
                                    "Intermediate" => "bg-warning text-dark",
                                    "Advanced" => "bg-danger",
                                    _ => "bg-secondary"
                                };
                            }
                            <span class="badge @levelClass">@course.Level</span>
                        </td>
                        <td>@(course.Price == 0 ? "Free" : $"${course.Price:F2}")</td>
                        <td>
                            @if (course.IsPublished)
                            {
                                <span class="badge bg-success">Published</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Draft</span>
                            }
                        </td>
                        <td>
                            <a asp-page="Edit" asp-route-id="@course.CourseId" class="btn btn-sm btn-outline-primary me-1">Edit</a>
                            <form asp-page-handler="Delete" asp-route-id="@course.CourseId" method="post" style="display:inline"
                                  onsubmit="return confirm('Delete this course?')">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <p class="text-muted">Total: @Model.Courses.Count() courses</p>
</div>
