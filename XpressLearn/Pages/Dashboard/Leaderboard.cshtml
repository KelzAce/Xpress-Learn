@page
@model XpressLearn.Pages.Dashboard.LeaderboardModel
@{
    ViewData["Title"] = "Leaderboard";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2">🏆 Leaderboard</h1>
        <button id="refreshBtn" class="btn btn-outline-primary">
            <span id="refreshSpinner" class="spinner-border spinner-border-sm d-none" role="status"></span>
            🔄 Refresh
        </button>
    </div>
    <p class="text-muted">Top scorer per category, ranked by best score.</p>

    <div id="leaderboardContainer">
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2 text-muted">Loading leaderboard...</p>
        </div>
    </div>
</div>

@section Scripts {
<script>
    async function loadLeaderboard() {
        const container = document.getElementById('leaderboardContainer');
        const spinner = document.getElementById('refreshSpinner');
        spinner.classList.remove('d-none');

        try {
            const response = await fetch('/Dashboard/Leaderboard?handler=LeaderboardData');
            if (!response.ok) throw new Error('Network response was not ok');
            const data = await response.json();

            if (!data || data.length === 0) {
                container.innerHTML = `
                    <div class="alert alert-info">
                        <strong>No leaderboard data yet.</strong> Complete some course attempts to appear here.
                    </div>`;
                return;
            }

            let tableHtml = `
                <div class="table-responsive">
                    <table class="table table-hover align-middle shadow-sm">
                        <thead class="table-dark">
                            <tr>
                                <th>#</th>
                                <th>Category</th>
                                <th>Top Student</th>
                                <th>Username</th>
                                <th>Best Score</th>
                                <th>Score Bar</th>
                            </tr>
                        </thead>
                        <tbody>`;

            data.forEach((entry, index) => {
                const fullName = [entry.firstName, entry.lastName].filter(Boolean).join(' ') || entry.username;
                const score = parseFloat(entry.bestScore).toFixed(2);
                const scorePercent = Math.min(100, parseFloat(entry.bestScore));
                const barClass = scorePercent >= 90 ? 'bg-success' : scorePercent >= 70 ? 'bg-warning' : 'bg-danger';

                tableHtml += `
                    <tr>
                        <td><span class="badge bg-secondary">${index + 1}</span></td>
                        <td><strong>${entry.categoryName}</strong></td>
                        <td>${fullName}</td>
                        <td><code>${entry.username}</code></td>
                        <td><span class="fw-bold text-success">${score}</span><small class="text-muted"> / 100</small></td>
                        <td style="min-width:150px;">
                            <div class="progress" style="height:18px;">
                                <div class="progress-bar ${barClass}" role="progressbar"
                                    style="width:${scorePercent}%"
                                    aria-valuenow="${scorePercent}" aria-valuemin="0" aria-valuemax="100">
                                    ${score}%
                                </div>
                            </div>
                        </td>
                    </tr>`;
            });

            tableHtml += `</tbody></table></div>
                <p class="text-muted text-end">Last updated: ${new Date().toLocaleTimeString()}</p>`;
            container.innerHTML = tableHtml;

        } catch (err) {
            container.innerHTML = `
                <div class="alert alert-danger">
                    <strong>Error loading leaderboard:</strong> ${err.message}
                </div>`;
        } finally {
            spinner.classList.add('d-none');
        }
    }

    document.getElementById('refreshBtn').addEventListener('click', loadLeaderboard);
    loadLeaderboard();
</script>
}
